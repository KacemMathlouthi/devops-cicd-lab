{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Pods Up",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(up{namespace=\"demo\",job=\"devops-cicd-lab\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Pod Restarts (total)",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [
        {
          "expr": "sum(kube_pod_container_status_restarts_total{namespace=\"demo\",pod=~\"devops-cicd-lab-.*\"})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Requests/sec",
      "gridPos": {"h": 4, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(app_requests_total{namespace=\"demo\"}[1m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}},
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Pod CPU",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {
          "expr": "sum by (pod) (rate(container_cpu_usage_seconds_total{namespace=\"demo\",pod=~\"devops-cicd-lab-.*\",container=\"app\"}[2m]))",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "percentunit"}}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Pod Memory (working set)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "expr": "sum by (pod) (container_memory_working_set_bytes{namespace=\"demo\",pod=~\"devops-cicd-lab-.*\",container=\"app\"})",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "App Request Rate by Endpoint",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 12},
      "targets": [
        {
          "expr": "sum by (endpoint) (rate(app_requests_total{namespace=\"demo\"}[1m]))",
          "legendFormat": "{{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    }
  ],
  "refresh": "30s",
