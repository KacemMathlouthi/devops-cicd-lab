# Copy to .env and fill in. .env is gitignored.

# GID of the host's docker group; lets the Jenkins container talk to /var/run/docker.sock.
# Find it with: getent group docker | cut -d: -f3
DOCKER_GID=999

# SonarCloud token used by the sonar-scanner stage in the Jenkinsfile.
# Generate at https://sonarcloud.io > My Account > Security > Tokens.
SONAR_TOKEN=replace-me

# Docker Hub credentials used by the docker push stage.
DOCKERHUB_USERNAME=replace-me
DOCKERHUB_TOKEN=replace-me

# Resend SMTP credentials used by AlertManager to send alert emails.
# Sign up at https://resend.com and create an API key (starts with re_).
# RESEND_TO_EMAIL is the address that will receive the alerts; it must match
# the email you signed up with if using the onboarding@resend.dev sender.
RESEND_API_KEY=re_replace-me
RESEND_TO_EMAIL=you@example.com
